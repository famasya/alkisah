{
	"name": "tanstack-start-example-basic-cloudflare",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && tsc --noEmit",
		"preview": "vite preview",
		"deploy": "wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"lint": "bunx oxlint --fix . && bunx oxfmt --write .",
		"lint:check": "bunx oxlint . && bunx oxfmt --check .",
		"format": "bunx oxfmt --write .",
		"typecheck": "tsc --noEmit",
		"cf-typegen": "wrangler types",
		"postinstall": "npm run cf-typegen"
	},
	"dependencies": {
		"@ai-sdk/openai-compatible": "^2.0.35",
		"@clerk/tanstack-react-start": "^1.0.4",
		"@clerk/themes": "^2.4.57",
		"@elevenlabs/elevenlabs-js": "^2.39.0",
		"@openrouter/sdk": "^0.9.11",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/postcss": "^4.2.1",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.167.0",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.11",
		"ai": "^6.0.134",
		"aws4fetch": "^1.0.20",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.1",
		"framer-motion": "^12.36.0",
		"lucide-react": "^0.577.0",
		"nanoid": "^5.1.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hot-toast": "^2.6.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.28.0",
		"@types/bun": "^1.3.10",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.4.27",
		"drizzle-kit": "^0.31.9",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-tsconfig-paths": "^6.1.1",
		"wrangler": "^4.73.0"
	}
}
